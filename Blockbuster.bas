100 REM BLOCKS
110 MODE 2:PRINT TAB(0,30);:W=19:D=29
120 BL=19:DIM P$(10),B(10),T(10)
200 INPUT"TOP ROW ";TR:GOSUB 3000
210 INPUT"BOTTOM ROW ";BR:GOSUB 3000:IF BR>D THEN LET BR=D
220 INPUT"LEFT COLUMN ";LC:GOSUB 3000
230 INPUT"RIGHT COLUMN ";RC:GOSUB 3000:IF RC>W THEN LET RC=W
240 INPUT"PATTERN LENGTH ";N:GOSUB 3000
250 FOR J=1 TO N
260 PRINT"CHARACTER ";J;" ";:INPUT LINE P$(J)
270 GOSUB 3000:INPUT"BACKGROUND(0-15)";B(J)
280 GOSUB 3000:INPUT"TEXT(0-15)";T(J)
300 GOSUB 3000:NEXT J:LET J=1
310 FOR R=TR TO BR
320 FOR C=LC TO RC
330 COLOUR 128+B(J):COLOUR T(J):PRINT TAB(C,R);LEFT$(P$(J),1)
340 LET J=J+1:IF J>N THEN LET J=1
350 NEXT C:NEXT R
355 COLOUR 128:COLOUR 7:PRINT TAB(0,30);
360 INPUT"ANOTHER GO (Y/N)";A$
370 GOSUB 3000:IF A$="Y" THEN GOTO 200
380 END
1000 FOR J=0 TO 1:VDU 23,224+J
1010 FOR N=1 TO 8:READ D:VDU D:NEXT N
1020 NEXT J:U$=CHR$224:Z$=CHR$225:RETURN
2000 DEF FNR(N)=RND(N)
2010 RETURN
3000 PRINT CHR$11;SPC(BL);CHR$13;:RETURN
4000 PRINT TAB(C,R);:RETURN
5000 PRINT TAB(H,V);:RETURN
6000 PRINT TAB(P,L);:RETURN
7000 K$=INKEY$(0):RETURN