100 REM INVADERS
110 GOSUB 1000:LET BL=1:GOSUB 2000
120 DATA 255,153,153,255,255,153,153,255,0,129,126,24,126,255,231,189
130 MODE 1:VDU 23,1,0;0;0;0;19,1,5;0;
135 *FX 11,20
140 COLOUR 1:V=30:W=38:H=19
150 DIM R(W):DIM C(W):DIM H(W):LET S=0
160 LET N=W:LET L$=CHR$(94):FOR C=1 TO W
170 LET C(C)=C:LET H(C)=V-5+FNR(4)
180 FOR R=H(C) TO V-1:GOSUB 4000:PRINT U$
190 NEXT R:NEXT C:LET P=H
200 COLOUR 2:A=RND(N+2)
210 IF A>N THEN GOTO 290
220 LET R=R(A):LET C=C(A):GOSUB 4000
230 PRINT" ":GOSUB 5000:PRINT L$
240 LET R=R+1:LET C=C+FNR(3)-2
250 LET R(A)=R:IF C<1 THEN LET C=1
260 IF C>W THEN LET C=W
270 LET C(A)=C:GOSUB 4000:PRINT Z$
280 IF R>H(C)-2 THEN GOTO 460
290 FOR T=1 TO 4:K$=INKEY$(8)
300 IF K$="Z" AND H>1 THEN LET H=H-1:GOSUB 5000:PRINT L$;" ":LET P=H
310 IF K$="X" AND H<W THEN GOSUB 5000:PRINT" ";L$:LET H=H+1:LET P=H
320 NEXT T:IF K$<>"F" THEN GOTO 200
330 LET L=H(H)-1:GOSUB 6000:PRINT"!"
340 COLOUR 3:M=POINT(32*H,1024-32*L)-1
350 GOSUB 6000:PRINT" ":LET L=L-1
360 IF L=0 THEN GOTO 200
370 IF M=1 THEN LET N=N-1:GOTO 390
380 GOSUB 6000:PRINT"!":GOTO 340
390 LET K=1:LET S=S+5*(30+W-N-L)
400 IF R(K)=L AND C(K)=H THEN GOTO 420
410 LET K=K+1:GOTO 400
420 SOUND 1,-15,53,4:PRINT TAB(H,L);" "
430 IF N=0 THEN LET M$="YOU HAVE SAVED LONDON":LET S=S+1000:GOTO 490
440 FOR T=K TO N:LET R(T)=R(T+1)
450 LET C(T)=C(T+1):NEXT T:GOTO 200
460 FOR R=H(C)-1 TO V:GOSUB 4000:PRINT" "
470 NEXT R:LET R=V-1:GOSUB 4000:PRINT Z$
480 LET M$="THE INVADERS HAVE LANDED"
490 LET R=2:LET C=2:GOSUB 4000:PRINT M$
495 *FX 12
500 PRINT:PRINT"     YOU SCORED ";S:STOP
1000 FOR J=0 TO 1:VDU 23,224+J
1010 FOR N=1 TO 8:READ D:VDU D:NEXT N
1020 NEXT J:U$=CHR$224:Z$=CHR$225:RETURN
2000 DEF FNR(N)=RND(N)
2010 RETURN
3000 PRINT CHR$11;SPC(BL);CHR$13;:RETURN
4000 PRINT TAB(C,R);:RETURN
5000 PRINT TAB(H,V);:RETURN
6000 PRINT TAB(P,L);:RETURN
7000 K$=INKEY$(0):RETURN